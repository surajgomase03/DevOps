{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadJenkinsDockerHubPracticalSecret",
      "Effect": "Allow",
      "Action": [
        "secretsmanager:GetSecretValue",
        "secretsmanager:DescribeSecret"
      ],
      "Resource": "arn:aws:secretsmanager:ap-south-1:REPLACE_AWS_ACCOUNT_ID:secret:dev/dockerhub/jenkins-practical-*"
    }
  ]
}
